{
  "schema": "brc.output_control_snapshots.v1",
  "status": "current",
  "scope": "live_enablement_output_version_control_boundary",
  "rules": {
    "commit_rule": "Only commit output artifacts when they are named task deliverables, generated by a known command, consumed by the main control path, and validated by a script.",
    "default_for_output": "deny_from_routine_commits",
    "git_tracking_rule": "Only paths listed in control_snapshots may remain tracked under output/**. All other output paths must stay untracked and ignored unless this manifest is updated first.",
    "historical_tracked_output": "existing non-snapshot output files are local compatibility evidence only after cleanup; modification does not make them routine commit candidates"
  },
  "control_snapshots": [
    {
      "path": "output/runtime-monitor/latest-daily-live-enablement-table.json",
      "paired_path": "output/runtime-monitor/latest-daily-live-enablement-table.md",
      "source_command": "python3 scripts/build_daily_live_enablement_table.py --require-database-url",
      "validator": "python3 scripts/validate_daily_live_enablement_table.py output/runtime-monitor/latest-daily-live-enablement-table.json",
      "consumed_by": "daily_live_enablement_status"
    },
    {
      "path": "output/runtime-monitor/latest-strategygroup-tradeability-decision.json",
      "paired_path": "output/runtime-monitor/latest-strategygroup-tradeability-decision.md",
      "source_command": "python3 scripts/build_strategygroup_tradeability_decision.py --require-database-url",
      "validator": "python3 -m py_compile scripts/build_strategygroup_tradeability_decision.py",
      "consumed_by": "daily_live_enablement_table"
    },
    {
      "path": "output/runtime-monitor/latest-replay-live-parity-audit.json",
      "paired_path": "output/runtime-monitor/latest-replay-live-parity-audit.md",
      "source_command": "python3 scripts/build_replay_live_parity_audit.py",
      "validator": "python3 -m py_compile scripts/build_replay_live_parity_audit.py",
      "consumed_by": "daily_live_enablement_table"
    },
    {
      "path": "output/runtime-monitor/latest-strategy-fresh-signal-action-time-boundary.json",
      "paired_path": "output/runtime-monitor/latest-strategy-fresh-signal-action-time-boundary.md",
      "source_command": "python3 scripts/build_strategy_fresh_signal_action_time_boundary.py --require-database-url",
      "validator": "python3 -m py_compile scripts/build_strategy_fresh_signal_action_time_boundary.py",
      "consumed_by": "daily_live_enablement_table"
    },
    {
      "path": "output/runtime-monitor/latest-local-monitor-sequence.json",
      "paired_path": "output/runtime-monitor/latest-local-monitor-sequence.md",
      "source_command": "python3 scripts/run_strategygroup_runtime_local_monitor_sequence.py --json",
      "validator": "python3 -m py_compile scripts/run_strategygroup_runtime_local_monitor_sequence.py",
      "consumed_by": "development_diagnostic_refresh"
    },
    {
      "path": "output/runtime-monitor/latest-single-lane-task-packet.json",
      "paired_path": "output/runtime-monitor/latest-single-lane-task-packet.md",
      "source_command": "python3 scripts/build_single_lane_task_packet.py --require-database-url",
      "validator": "python3 scripts/validate_single_lane_task_packet.py output/runtime-monitor/latest-single-lane-task-packet.json",
      "consumed_by": "single_lane_task_packet_gate"
    },
    {
      "path": "output/runtime-monitor/latest-strategy-live-candidate-pool.json",
      "paired_path": "output/runtime-monitor/latest-strategy-live-candidate-pool.md",
      "source_command": "python3 scripts/build_strategy_live_candidate_pool.py --require-database-url",
      "validator": "python3 scripts/validate_strategy_live_candidate_pool.py output/runtime-monitor/latest-strategy-live-candidate-pool.json",
      "consumed_by": "live_candidate_pool_deploy_gate"
    }
  ],
  "volatile_output_globs": [
    "output/runtime-monitor/latest-binance-usdm-public-facts.*",
    "output/runtime-monitor/latest-*-runtime-signal-*",
    "output/runtime-monitor/latest-*-shadow-candidate-evidence.*",
    "output/runtime-monitor/latest-*-required-facts-mapping.*",
    "output/runtime-monitor/latest-*-owner-trial-policy-scope.*",
    "output/runtime-monitor/latest-*-expanded-watcher-facts.*",
    "output/runtime-monitor/latest-runtime-replay-lab.*",
    "output/runtime-monitor/latest-runtime-dry-run-audit-chain.json",
    "output/runtime-monitor/runtime-dry-run-audit-chain/**",
    "output/strategygroup-runtime-pilot/**",
    "output/tokyo-*.json",
    "output/runtime-monitor/latest-tokyo-*.json"
  ],
  "authority_boundary": {
    "finalgate_called": false,
    "operation_layer_called": false,
    "exchange_write_called": false,
    "live_profile_changed": false,
    "order_sizing_changed": false
  }
}
