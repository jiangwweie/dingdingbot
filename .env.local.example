# Local Environment Variables Example
# Copy this file to .env.local and customize for your local setup
# DO NOT commit .env.local to git

# =============================================================================
# PostgreSQL Configuration (Local Development)
# =============================================================================

# PostgreSQL Connection URL
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
APP_ENV=development
TRADING_ENV=testnet
PG_DATABASE_URL=postgresql+asyncpg://dingdingbot:dingdingbot_dev@localhost:5432/dingdingbot

# Core Backend Selection (all PG for runtime mainline)
CORE_EXECUTION_INTENT_BACKEND=postgres
CORE_ORDER_BACKEND=postgres
CORE_POSITION_BACKEND=postgres

# =============================================================================
# Runtime Configuration
# =============================================================================

# Runtime Profile (required for local BRC acceptance)
# Dev/testnet only. Do not use RUNTIME_PROFILE as a live execution selector.
RUNTIME_PROFILE=brc_btc_eth_testnet_runtime
BRC_EXECUTION_PERMISSION_MAX=intent_recording

# Service Ports
FRONTEND_PORT=5173
BACKEND_PORT=8000

# Exchange Configuration (Binance Testnet)
EXCHANGE_NAME=binance
EXCHANGE_TESTNET=true
# EXCHANGE_API_KEY=your_testnet_api_key
# EXCHANGE_API_SECRET=your_testnet_api_secret

# Local BRC testnet acceptance gates.
# Keep these enabled only for local/dev testnet rehearsal.
RUNTIME_CONTROL_API_ENABLED=true
RUNTIME_TEST_SIGNAL_INJECTION_ENABLED=true

# Notification
# FEISHU_WEBHOOK_URL=your_feishu_webhook_url

# =============================================================================
# Notes
# =============================================================================
#
# 1. DO NOT commit this file with real secrets to git
# 2. Use .env.local for local development (not tracked by git)
# 3. The main .env file is NO LONGER tracked by git — do not re-add it
# 4. For local PG setup, see docs/local-pg.md
#
# =============================================================================
