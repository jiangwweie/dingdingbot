# .env.tiny-live.example
#
# Template for 50U engineering tiny-live rehearsal.
# Copy to .env.tiny-live and fill in real values.
# NEVER commit .env.tiny-live to git.
#
# ⚠️  This file configures LIVE exchange access with REAL funds.
# ⚠️  Owner must approve before starting the runtime with these settings.

# ─── PG Database ───────────────────────────────────────────────
# Use a dedicated database, NOT the testnet DB.
# Create: CREATE DATABASE dingdingbot_tinylive;
PG_DATABASE_URL=postgresql+asyncpg://dingdingbot:<password>@localhost:5432/dingdingbot_tinylive

CORE_EXECUTION_INTENT_BACKEND=postgres
CORE_ORDER_BACKEND=postgres
CORE_POSITION_BACKEND=postgres

# ─── Runtime Profile ───────────────────────────────────────────
RUNTIME_PROFILE=tiny_live_50u_eth

# ─── Exchange (LIVE) ───────────────────────────────────────────
EXCHANGE_NAME=binance
EXCHANGE_TESTNET=false
# ⚠️  LIVE API key — never log, never commit, never print
EXCHANGE_API_KEY=<your-live-api-key>
EXCHANGE_API_SECRET=<your-live-api-secret>

# ─── Notifications ─────────────────────────────────────────────
FEISHU_WEBHOOK_URL=<your-feishu-webhook-url>
# Enable protection health Feishu alerts for tiny-live
PROTECTION_HEALTH_EXTERNAL_ALERTS_ENABLED=true

# ─── Server ────────────────────────────────────────────────────
BACKEND_PORT=8000
API_HOST=127.0.0.1

# ─── Control flags ─────────────────────────────────────────────
# Runtime control API: must be true for GKS/arm control at startup
RUNTIME_CONTROL_API_ENABLED=true
# Test signal injection: MUST be false for live
RUNTIME_TEST_SIGNAL_INJECTION_ENABLED=false
