# Tokyo experimental live order-capable overlay.
#
# Purpose:
# - This is the bounded experiment profile for real orders after the official
#   StrategyGroup runtime chain proves readiness.
# - Keep real credentials in the server secret store or the base env file.
# - Never commit filled credentials.
#
# Recommended server path:
#   /home/ubuntu/brc-deploy/env/runtime-order-capable.env
#
# This file is intentionally small. It overrides the prelive/read-only ceiling
# without changing credentials, selected StrategyGroup scope, symbol universe,
# leverage, notional, or sizing defaults.

TRADING_ENV=live
EXCHANGE_TESTNET=false
BRC_EXECUTION_PERMISSION_MAX=order_allowed

# Live/test mutation surfaces remain closed. Runtime execution must still pass
# FinalGate and the official Operation Layer.
RUNTIME_CONTROL_API_ENABLED=false
RUNTIME_TEST_SIGNAL_INJECTION_ENABLED=false

# Enables the runtime-owned exchange gateway binding only after the official
# Operation Layer requests real_gateway_action with complete evidence.
RUNTIME_EXCHANGE_SUBMIT_GATEWAY_BINDING_ENABLED=true

# Non-secret credential identity. Runtime compares this binding with the PG
# Ticket account and exchange before any exchange read or write.
BRC_RUNTIME_EXCHANGE_ACCOUNT_ID=owner-subaccount-runtime-v0
BRC_RUNTIME_EXCHANGE_ID=binance_usdm

# Enables only the durable claim -> commit -> exchange I/O -> result worker.
# Legacy lifecycle direct mutation remains unreachable.

# Optional documentation-only marker for masked status packets.
BRC_RUNTIME_ORDER_CAPABLE_EXPERIMENT=true
