# Production Owner Console / live read-only deployment template.
# Store real values on the server secret store or host environment.
# Never commit filled credentials.

APP_ENV=production
TRADING_ENV=live
EXCHANGE_TESTNET=false

PG_DATABASE_URL=<set_on_server>
CORE_EXECUTION_INTENT_BACKEND=postgres
CORE_ORDER_BACKEND=postgres
CORE_POSITION_BACKEND=postgres

BRC_OPERATOR_USERNAME=owner
BRC_OPERATOR_PASSWORD_HASH=<set_on_server>
BRC_OPERATOR_TOTP_SECRET=<set_on_server>
BRC_OPERATOR_SESSION_SECRET=<set_on_server>
BRC_OPERATOR_SESSION_TTL_SECONDS=86400

EXCHANGE_NAME=binance
EXCHANGE_API_KEY=<set_on_server>
EXCHANGE_API_SECRET=<set_on_server>

# Production/live must remain globally read-only.
# Any future live trial scope must resolve from PG-backed Owner authorization.
BRC_EXECUTION_PERMISSION_MAX=read_only
RUNTIME_CONTROL_API_ENABLED=false
RUNTIME_TEST_SIGNAL_INJECTION_ENABLED=false

BRC_LLM_ENABLED=false
# BRC_LLM_BASE_URL=<optional>
# BRC_LLM_API_KEY=<optional>
# BRC_LLM_MODEL=<optional>

BACKEND_PORT=8000
API_HOST=127.0.0.1

# Optional: set on server only if production notification is explicitly enabled.
# FEISHU_WEBHOOK_URL=<set_on_server_if_enabled>
