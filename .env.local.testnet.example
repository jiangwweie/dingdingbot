# Local testnet Owner Console / controlled rehearsal template.
# Copy to .env.local and fill values on the local machine only.
# Never commit real credentials.

APP_ENV=development
TRADING_ENV=testnet
EXCHANGE_TESTNET=true

PG_DATABASE_URL=postgresql+asyncpg://dingdingbot:dingdingbot_dev@localhost:5432/dingdingbot
CORE_EXECUTION_INTENT_BACKEND=postgres
CORE_ORDER_BACKEND=postgres
CORE_POSITION_BACKEND=postgres

BRC_OPERATOR_USERNAME=owner
BRC_OPERATOR_PASSWORD_HASH=<set_locally>
BRC_OPERATOR_TOTP_SECRET=<set_locally>
BRC_OPERATOR_SESSION_SECRET=<set_locally>
BRC_OPERATOR_SESSION_TTL_SECONDS=86400

EXCHANGE_NAME=binance
EXCHANGE_API_KEY=<set_locally_testnet>
EXCHANGE_API_SECRET=<set_locally_testnet>

# Dev/testnet only: selects the controlled rehearsal profile, not live scope.
RUNTIME_PROFILE=brc_btc_eth_testnet_runtime
BRC_EXECUTION_PERMISSION_MAX=intent_recording
RUNTIME_CONTROL_API_ENABLED=true
RUNTIME_TEST_SIGNAL_INJECTION_ENABLED=true

BRC_LLM_ENABLED=false
# BRC_LLM_BASE_URL=<optional>
# BRC_LLM_API_KEY=<optional>
# BRC_LLM_MODEL=<optional>

FRONTEND_PORT=5173
BACKEND_PORT=8000
API_HOST=127.0.0.1

# Optional non-secret notification toggle. Put real webhook values on the host.
# FEISHU_WEBHOOK_URL=<set_locally_if_needed>
