[Unit]
Description=BRC ticket-bound lifecycle maintenance
Wants=network-online.target
After=network-online.target brc-owner-console-backend.service

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/brc-deploy/app/current
EnvironmentFile=/home/ubuntu/brc-deploy/env/live-readonly.env
EnvironmentFile=-/home/ubuntu/brc-deploy/env/runtime-order-capable.env
EnvironmentFile=-/home/ubuntu/brc-deploy/env/ticket-lifecycle-maintenance.env
ExecStartPre=/usr/bin/timeout --foreground --signal=TERM --kill-after=2s 8s /home/ubuntu/brc-deploy/app/current/.venv/bin/python /home/ubuntu/brc-deploy/control-plane/check_runtime_postgres_ready.py --require-database-url --timeout-seconds 8
ExecStart=/usr/bin/timeout --foreground --signal=TERM --kill-after=2s 36s /home/ubuntu/brc-deploy/app/current/.venv/bin/python scripts/run_ticket_bound_lifecycle_maintenance_once.py --require-database-url --max-lifecycle-scopes 1 --max-actions-per-scope 16 --snapshot-timeout-seconds 8 --global-deadline-seconds 28 --entry-command-timeout-seconds 6 --initial-stop-command-timeout-seconds 6 --tp1-command-timeout-seconds 4 --deadline-commit-margin-seconds 5 --entry-result-commit-reserve-seconds 1 --initial-stop-result-commit-reserve-seconds 1 --deadline-shutdown-reserve-seconds 1
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
Nice=10
CPUAccounting=true
CPUQuota=40%
IOAccounting=true
IOSchedulingClass=best-effort
IOSchedulingPriority=6
TimeoutStartSec=45s
TimeoutStopSec=10s
KillMode=control-group
