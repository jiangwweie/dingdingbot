[Unit]
Description=BRC runtime signal watcher tick
Wants=network-online.target
After=network-online.target brc-owner-console-backend.service

[Service]
Type=oneshot
WorkingDirectory=/home/ubuntu/brc-deploy/app/current
EnvironmentFile=/home/ubuntu/brc-deploy/env/live-readonly.env
EnvironmentFile=-/home/ubuntu/brc-deploy/env/runtime-signal-watcher.env
ExecStart=/home/ubuntu/brc-deploy/venvs/brc-bnb-prelive-20260601/bin/python scripts/runtime_signal_watcher_tick.py \
  --env-file /home/ubuntu/brc-deploy/env/live-readonly.env \
  --api-base http://127.0.0.1:18080 \
  --source live_market \
  --strategy-source live_market \
  --output-dir /home/ubuntu/brc-deploy/reports/runtime-signal-watcher \
  --max-iterations 1 \
  --cycle-timeout-seconds 180 \
  --status-stale-after-seconds 900 \
  --label tokyo-runtime-signal-watcher

NoNewPrivileges=true
PrivateTmp=true
