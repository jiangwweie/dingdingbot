[Unit]
Description=BRC runtime-control-state PG retention cleanup
Wants=network-online.target
After=network-online.target brc-owner-console-backend.service

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/brc-deploy/app/current
EnvironmentFile=/home/ubuntu/brc-deploy/env/live-readonly.env
EnvironmentFile=-/home/ubuntu/brc-deploy/env/runtime-monitor.env
ExecStart=/home/ubuntu/brc-deploy/venvs/brc-bnb-prelive-20260601/bin/python scripts/run_runtime_control_state_retention.py \
  --apply \
  --json

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
