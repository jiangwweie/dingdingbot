{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/personal_campaign/campaign_state.schema.json",
  "title": "CampaignState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "campaign_id",
    "capital_bucket",
    "status",
    "active_strategy_contract_id",
    "active_session_id",
    "realized_pnl",
    "unrealized_pnl",
    "loss_lock",
    "profit_protect_active",
    "hard_lock_reason",
    "rule_version",
    "invariant_checks"
  ],
  "properties": {
    "campaign_id": { "type": "string", "minLength": 1 },
    "capital_bucket": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
    "status": { "type": "string", "enum": ["observe", "armed", "paused", "hard_locked"] },
    "active_strategy_contract_id": { "type": ["string", "null"] },
    "active_session_id": { "type": ["string", "null"] },
    "realized_pnl": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" },
    "unrealized_pnl": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" },
    "loss_lock": { "type": "boolean" },
    "profit_protect_active": { "type": "boolean" },
    "hard_lock_reason": { "type": ["string", "null"] },
    "rule_version": { "type": "string", "const": "personal_campaign_local_v0" },
    "invariant_checks": { "type": "array", "items": { "type": "string" } }
  }
}
