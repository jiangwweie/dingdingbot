{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/personal_campaign/strategy_contract.schema.json",
  "title": "StrategyContract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "strategy_contract_id",
    "strategy_name",
    "contract_status",
    "disabled_by_default",
    "runtime_label",
    "setup_condition_key",
    "invalidation_condition_key",
    "entry_action",
    "direction",
    "required_feature_snapshot",
    "forbidden_data",
    "no_lookahead_rule"
  ],
  "properties": {
    "strategy_contract_id": { "type": "string", "minLength": 1 },
    "strategy_name": { "type": "string", "minLength": 1 },
    "contract_status": { "type": "string", "const": "frozen", "default": "frozen" },
    "disabled_by_default": { "type": "boolean", "const": true, "default": true },
    "runtime_label": {
      "type": "string",
      "const": "LOCAL_SANDBOX_ONLY_DISABLED_BY_DEFAULT",
      "default": "LOCAL_SANDBOX_ONLY_DISABLED_BY_DEFAULT"
    },
    "setup_condition_key": { "type": "string", "minLength": 1 },
    "invalidation_condition_key": { "type": "string", "minLength": 1 },
    "entry_action": { "type": "string", "enum": ["enter", "exit", "reduce", "none"] },
    "direction": { "type": "string", "enum": ["LONG", "SHORT"] },
    "required_feature_snapshot": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_data": {
      "type": "array",
      "contains": { "const": "lookahead" },
      "items": { "type": "string" }
    },
    "no_lookahead_rule": {
      "type": "string",
      "const": "closed_or_prior_inputs_only",
      "default": "closed_or_prior_inputs_only"
    }
  }
}
