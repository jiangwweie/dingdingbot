{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/personal_campaign/read_only_runtime_adapter_preview.schema.json",
  "title": "ReadOnlyRuntimeAdapterPreview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adapter_version",
    "read_only",
    "authority",
    "source_snapshot_id",
    "snapshot_feature_timestamp_ms",
    "runtime_clock_ms",
    "strategy_contract_id",
    "strategy_contract_status",
    "trade_intent",
    "rejection_reasons",
    "no_exchange_side_effect"
  ],
  "properties": {
    "adapter_version": {
      "type": "string",
      "const": "plc_read_only_runtime_adapter_v1",
      "default": "plc_read_only_runtime_adapter_v1"
    },
    "read_only": { "type": "boolean", "const": true, "default": true },
    "authority": {
      "type": "string",
      "const": "read_only_no_order_authority",
      "default": "read_only_no_order_authority"
    },
    "source_snapshot_id": { "type": "string", "minLength": 1 },
    "snapshot_feature_timestamp_ms": { "type": "integer", "minimum": 0 },
    "runtime_clock_ms": { "type": "integer", "minimum": 0 },
    "strategy_contract_id": { "type": "string", "minLength": 1 },
    "strategy_contract_status": { "type": "string", "const": "frozen" },
    "trade_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "strategy_contract_id",
        "campaign_id",
        "session_id",
        "direction",
        "action",
        "trigger_reason",
        "invalidation_reason",
        "evidence_text",
        "no_exchange_side_effect"
      ],
      "properties": {
        "decision": { "type": "string", "enum": ["allow", "reject"] },
        "strategy_contract_id": { "type": "string", "minLength": 1 },
        "campaign_id": { "type": "string", "const": "read-only-runtime-preview" },
        "session_id": { "type": "string", "minLength": 1 },
        "direction": { "type": ["string", "null"], "enum": ["LONG", "SHORT", null] },
        "action": { "type": "string", "enum": ["enter", "exit", "reduce", "none"] },
        "trigger_reason": { "type": "string", "minLength": 1 },
        "invalidation_reason": { "type": ["string", "null"] },
        "evidence_text": { "type": ["string", "null"] },
        "no_exchange_side_effect": { "type": "boolean", "const": true, "default": true }
      }
    },
    "rejection_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "no_exchange_side_effect": { "type": "boolean", "const": true, "default": true }
  },
  "not": {
    "anyOf": [
      { "required": ["order_id"] },
      { "required": ["exchange_order_id"] }
    ]
  }
}
