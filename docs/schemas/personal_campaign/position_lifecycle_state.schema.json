{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/personal_campaign/position_lifecycle_state.schema.json",
  "title": "PositionLifecycleState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "campaign_id",
    "session_id",
    "source_of_truth",
    "status",
    "protection_state",
    "reduce_or_close_required",
    "hard_lock_required",
    "reasons"
  ],
  "properties": {
    "campaign_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "source_of_truth": { "type": "string", "const": "local_sandbox", "default": "local_sandbox" },
    "status": {
      "type": "string",
      "enum": ["no_position", "open_protected", "reduce_required", "close_required", "hard_locked"]
    },
    "protection_state": { "type": "string", "enum": ["none", "protected", "protection_missing"] },
    "reduce_or_close_required": { "type": "boolean" },
    "hard_lock_required": { "type": "boolean" },
    "reasons": { "type": "array", "items": { "type": "string" } }
  }
}
