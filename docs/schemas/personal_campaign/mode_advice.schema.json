{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/personal_campaign/mode_advice.schema.json",
  "title": "ModeAdvice",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode_id",
    "strategy_contract_id",
    "why",
    "evidence",
    "caveats",
    "default_action",
    "llm_role"
  ],
  "properties": {
    "mode_id": { "type": "string", "minLength": 1 },
    "strategy_contract_id": { "type": "string", "minLength": 1 },
    "why": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "caveats": { "type": "array", "items": { "type": "string" } },
    "default_action": {
      "type": "string",
      "enum": ["observe", "arm", "pause", "ignore"],
      "default": "observe"
    },
    "llm_role": {
      "type": "string",
      "const": "explain_audit_suggest_only",
      "default": "explain_audit_suggest_only"
    }
  }
}
