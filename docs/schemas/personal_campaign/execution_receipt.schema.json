{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/personal_campaign/execution_receipt.schema.json",
  "title": "ExecutionReceipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "campaign_id",
    "session_id",
    "strategy_contract_id",
    "simulated_order_id",
    "acknowledgement",
    "reconciliation_reference",
    "protection_status",
    "lifecycle_status"
  ],
  "properties": {
    "status": { "type": "string", "enum": ["not_submitted", "simulated_accepted", "blocked"] },
    "campaign_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "strategy_contract_id": { "type": "string", "minLength": 1 },
    "simulated_order_id": { "type": ["string", "null"] },
    "acknowledgement": { "type": ["string", "null"] },
    "reconciliation_reference": { "type": ["string", "null"] },
    "protection_status": { "type": "string", "enum": ["none", "protected", "protection_missing"] },
    "lifecycle_status": {
      "type": "string",
      "enum": ["no_position", "open_protected", "reduce_required", "close_required", "hard_locked"]
    }
  }
}
