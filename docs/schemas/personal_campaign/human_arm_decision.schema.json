{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/personal_campaign/human_arm_decision.schema.json",
  "title": "HumanArmDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision",
    "strategy_contract_id",
    "campaign_id",
    "session_id",
    "allowed_from_ms",
    "allowed_until_ms",
    "decided_by",
    "audit_provenance",
    "reason"
  ],
  "properties": {
    "decision": { "type": "string", "enum": ["arm", "pause", "reject"] },
    "strategy_contract_id": { "type": "string", "minLength": 1 },
    "campaign_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "allowed_from_ms": { "type": "integer", "minimum": 0 },
    "allowed_until_ms": { "type": "integer", "minimum": 0 },
    "decided_by": { "type": "string", "minLength": 1 },
    "audit_provenance": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 }
  }
}
