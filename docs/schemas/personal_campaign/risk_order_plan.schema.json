{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/personal_campaign/risk_order_plan.schema.json",
  "title": "RiskOrderPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision",
    "campaign_id",
    "session_id",
    "strategy_contract_id",
    "reasons",
    "owner_fixed_caps_used",
    "planned_order",
    "protection_requirements",
    "rollback_and_cancellation"
  ],
  "properties": {
    "decision": { "type": "string", "enum": ["allow", "reject"] },
    "campaign_id": { "type": "string", "minLength": 1 },
    "session_id": { "type": "string", "minLength": 1 },
    "strategy_contract_id": { "type": "string", "minLength": 1 },
    "reasons": { "type": "array", "items": { "type": "string" } },
    "owner_fixed_caps_used": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "risk_capital",
        "max_order_loss",
        "max_campaign_loss",
        "max_notional",
        "max_leverage",
        "profit_protect_threshold"
      ],
      "properties": {
        "risk_capital": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "max_order_loss": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "max_campaign_loss": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "max_notional": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "max_leverage": { "type": "integer", "minimum": 1 },
        "profit_protect_threshold": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" }
      }
    },
    "planned_order": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["symbol", "side", "notional", "leverage", "max_loss", "order_type"],
      "properties": {
        "symbol": { "type": "string", "minLength": 1 },
        "side": { "type": "string", "enum": ["LONG", "SHORT"] },
        "notional": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "leverage": { "type": "integer", "minimum": 1 },
        "max_loss": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "order_type": { "type": "string", "const": "simulated_market" }
      }
    },
    "protection_requirements": { "type": "array", "items": { "type": "string" } },
    "rollback_and_cancellation": {
      "type": "string",
      "const": "local_plan_only_no_exchange_side_effect",
      "default": "local_plan_only_no_exchange_side_effect"
    }
  }
}
